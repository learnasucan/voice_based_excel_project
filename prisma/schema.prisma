generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContributionRow {
  id                 String   @id @default(cuid())
  serialNumber       Int      @unique
  nameMr             String
  nameEn             String
  entryType          String   @default("cash")
  contributionAmount Int?
  giftNameMr         String?
  giftNameEn         String?
  placeMr            String
  placeEn            String
  nameMrKey          String
  placeMrKey         String
  giftNameMrKey      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([entryType, nameMrKey, contributionAmount, giftNameMrKey, placeMrKey], name: "uniq_row_identity")
  @@index([nameMr])
  @@index([nameEn])
  @@index([entryType])
  @@index([giftNameMr])
  @@index([giftNameEn])
  @@index([placeMr])
  @@index([placeEn])
}
