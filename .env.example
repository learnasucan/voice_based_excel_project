# Runtime
NODE_ENV="development"
APP_BASE_URL="http://localhost:3000"

# Prisma / DB
DATABASE_URL="file:./dev.db"

# Public client values
NEXT_PUBLIC_APP_NAME="Record Studio MVP"
NEXT_PUBLIC_API_BASE_PATH="/api/v1"

# AI abstraction (stub | openai)
AI_PROVIDER="stub"
AI_API_KEY=""
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Speech abstraction (stub | openai-whisper | browser)
SPEECH_PROVIDER="stub"
SPEECH_API_KEY=""

# Export output root used by export worker
EXPORT_STORAGE_PATH="./tmp/exports"
